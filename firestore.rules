rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. GENEL OKUMA İZİNLERİ
    match /posts/{doc} { allow read: if true; }
    match /plays/{doc} { allow read: if true; }
    match /events/{doc} { allow read: if true; }
    match /teamNeeds/{doc} { allow read: if true; }
    
    // YOKLAMA SİSTEMİ
    match /rehearsals/{doc} { allow read: if true; }
    
    // 2. KULLANICI VERİLERİ
    match /users/{userId} {
      allow read: if request.auth != null; 
    }
    
    match /eventRequests/{reqId} {
      allow read: if request.auth != null;
    }

    // 3. GÜVENLİK BARİYERİ
    match /{document=**} {
      allow write: if false; 
    }
  }
}
